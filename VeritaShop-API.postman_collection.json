				{
					"name": "Update Profile - Partial",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"0987654321\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/profile",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"profile"
							]
						},
						"description": "Example of partial update - only updating phone number"
					},
					"response": []
				}
			],
			"description": "User profile management endpoints"
		},
		{
