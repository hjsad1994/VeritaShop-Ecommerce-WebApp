# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database Configuration
# Local Development (Docker PostgreSQL)
# Default credentials match docker-compose.yml
DATABASE_URL="postgresql://dbuser:dbpass123@localhost:5432/nextecommerce"

# Note: Use 127.0.0.1 instead of localhost if you encounter connection issues on Windows
# DATABASE_URL="postgresql://dbuser:dbpass123@127.0.0.1:5432/nextecommerce"

# Production (Update with your production database URL)
# DATABASE_URL="postgresql://username:password@production-host:5432/dbname"

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_ACCESS_TOKEN_EXPIRY=7d
JWT_REFRESH_TOKEN_EXPIRY=30d

# AWS S3 Configuration (for image uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# Instructions:
# 1. Copy this file to .env
# 2. Update all placeholder values with your actual credentials
# 3. For local development, use the Docker PostgreSQL connection string
# 4. Never commit .env file to version control
