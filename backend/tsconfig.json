{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": "./",
    "moduleResolution": "node",
    "paths": {
      "@constants": ["src/constants"],
      "@constants/*": ["src/constants/*"]
    }
  },
  "include": ["src/**/*", "prisma/**/*"]
}